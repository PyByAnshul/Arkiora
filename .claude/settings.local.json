      "Bash(.venv/bin/python -m pip install --quiet \"fastapi>=0.115\" \"uvicorn[standard]>=0.30\" \"sqlalchemy[asyncio]>=2.0\" \"asyncpg>=0.29\" \"psycopg[binary]>=3.1\" \"alembic>=1.13\" \"pydantic>=2.7\" \"pydantic-settings>=2.3\" \"python-jose[cryptography]>=3.3\" \"argon2-cffi>=23.1\" \"redis>=5.0\" \"python-multipart>=0.0.9\")",
      "Bash(echo \"EXIT=$?\")",

      "Bash(curl -s http://localhost:8000/health/live)",
      "Read(//tmp/**)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" http://localhost:8000/health/live)",
      "Bash(PYTHONPATH=. .venv/bin/alembic downgrade base)",
      "Bash(PYTHONPATH=. .venv/bin/alembic upgrade head)",
